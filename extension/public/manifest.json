{
  "manifest_version": 3,
  "name": "AI Helpdesk Assistant",
  "version": "1.8.0",
  "description": "Local AI assistant for SolarWinds Web Help Desk — powered by Ollama",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*/helpdesk/WebObjects/Helpdesk.woa/*",
        "*://*/helpdesk/*",
        "*://*/*ticketDetail*",
        "*://*/*/tickets/*"
      ],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidebar/index.html"
  },
  "options_page": "src/options/index.html",
  "action": {
    "default_title": "AI Helpdesk Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Alt+Shift+H",
        "windows": "Alt+Shift+H",
        "mac": "Alt+Shift+H"
      },
      "description": "Toggle the AI Helpdesk sidebar"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

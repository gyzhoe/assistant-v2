# AI Helpdesk Assistant — Backend Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11435

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_data

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set this to your exact extension origin.
# Find it at edge://extensions after loading the extension.
# Format: chrome-extension://<32-char-id>
CORS_ORIGIN=chrome-extension://REPLACE_WITH_YOUR_EXTENSION_ID

# ── LLM defaults ──────────────────────────────────────────────────────────────
DEFAULT_MODEL=qwen3.5:9b

# ── Enterprise Security ───────────────────────────────────────────────────────
# Shared secret between the extension and this backend.
# Auto-generated during installation. To regenerate manually: openssl rand -hex 32
# The extension auto-detects this value via native messaging.
# Leave empty ("") to disable token auth in dev.
API_TOKEN=REPLACE_WITH_STRONG_SECRET

# Rate limiting: max /generate calls per client IP per minute.
RATE_LIMIT_PER_MINUTE=20

# Max request body size in bytes (default 64 KB).
MAX_REQUEST_BYTES=65536
